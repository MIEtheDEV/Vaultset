# Vaultset environment variables.
# Copy this file to .env.local and fill in the values. .env.local is gitignored;
# this example is committed for onboarding/deploys. Restart the dev server after
# changing env vars (Next.js only reads them at startup).

# ── App ───────────────────────────────────────────────────────────────
# Public base URL (used for absolute links, Stripe redirect URLs, etc.).
# e.g. http://localhost:3000 locally, https://vaultset.app in production.
NEXT_PUBLIC_SITE_URL=

# ── Supabase (required) ───────────────────────────────────────────────
# Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Card pricing sources (all optional; an unset source is simply skipped) ──
# pokemontcg.io — bedrock catalog + raw market prices. Works without a key;
# a key only raises rate limits.
POKEMON_TCG_API_KEY=
# JustTCG — real-time raw prices + per-condition data + gap-filler search.
JUSTTCG_API_KEY=
# cardmarket-api-tcg via RapidAPI — graded slab medians (PSA/BGS/CGC/ACE/SGC/TAG).
TCGGO_RAPID_API_KEY=
# PokéWallet — scaffolded tier, not yet wired.
POKEWALLET_API_KEY=

# ── Stripe: subscriptions + donations (live) ──────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=
STRIPE_PRICE_SEMIANNUAL=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_DONATION=

# ── Stripe sandbox/test (optional, for local testing) ─────────────────
STRIPE_SANDBOX_SECRET_KEY=
STRIPE_SANDBOX_WEBHOOK_SECRET=
STRIPE_SANDBOX_PRICE_SINGLE=
STRIPE_SANDBOX_PRICE_MONTHLY=
STRIPE_SANDBOX_PRICE_QUARTERLY=
STRIPE_SANDBOX_PRICE_SEMIANNUAL=
STRIPE_SANDBOX_PRICE_ANNUAL=

# ── Auth: Google OAuth ────────────────────────────────────────────────
GOOGLE_OAUTH_ID=
GOOGLE_OAUTH_SECRET=

# ── Web push (VAPID) ──────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
PUSH_DISPATCH_SECRET=

# ── Donations / admin ─────────────────────────────────────────────────
KOFI_WEBHOOK_SECRET=
ADMIN_USERNAME=
# Owner email — exempt from the market-refresh 24h rate limit. Optional; if
# unset, everyone (including the owner) is rate-limited.
OWNER_EMAIL=

# ── E2E tests (Playwright) ────────────────────────────────────────────
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
